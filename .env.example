# ── Database (utilisé par Docker Compose ET Next.js) ──
DB_USER=viraza
DB_PASSWORD=viraza_secret
DB_NAME=viraza
DB_PORT=5432
DATABASE_URL=postgres://viraza:viraza_secret@localhost:5432/viraza

# ── Site ──────────────────────────────────────────────
NEXT_PUBLIC_DEFAULT_SITE_URL=http://localhost:3000

# ── Admin Auth ────────────────────────────────────────
ADMIN_PASSWORD=admin123

# ── c15t (optionnel) ──────────────────────────────────
NEXT_PUBLIC_C15T_MODE=
NEXT_PUBLIC_C15T_URL=https://your-instance.c15t.dev
